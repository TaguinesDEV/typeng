ScreenManager:
    LoginScreen:
    MenuScreen:
    GameScreen:
    ScoreboardScreen:

<LoginScreen>:
    name: "login"
    message: message
    BoxLayout:
        orientation: "vertical"
        padding: 24
        spacing: 12

        Label:
            text: "Typing Master"
            font_size: 36
            size_hint_y: None
            height: 60

        Label:
            text: "Log in or create an account to track your best scores."
            size_hint_y: None
            height: 40

        TextInput:
            id: username_input
            hint_text: "Username"
            multiline: False
            write_tab: False

        TextInput:
            id: password_input
            hint_text: "Password"
            password: True
            multiline: False
            write_tab: False

        Label:
            id: message
            text: ""
            color: 1, 0.2, 0.2, 1
            size_hint_y: None
            height: 30

        BoxLayout:
            size_hint_y: None
            height: 48
            spacing: 12

            Button:
                text: "Log In"
                on_press: root.do_login(username_input.text, password_input.text)

            Button:
                text: "Register"
                on_press: root.do_register(username_input.text, password_input.text)

        Button:
            text: "View Ranking"
            size_hint_y: None
            height: 48
            on_press:
                app.root.current = "scoreboard"

<MenuScreen>:
    name: "menu"
    BoxLayout:
        orientation: "vertical"
        padding: 24
        spacing: 12

        Label:
            text: root.welcome_text
            font_size: 32
            size_hint_y: None
            height: 60

        Label:
            text: root.best_score_text
            font_size: 20
            size_hint_y: None
            height: 40

        Button:
            text: "Start Typing Game"
            size_hint_y: None
            height: 48
            on_press: app.root.current = "game"

        Button:
            text: "View Ranking"
            size_hint_y: None
            height: 48
            on_press: app.root.current = "scoreboard"

        Button:
            text: "Logout"
            size_hint_y: None
            height: 48
            on_press: root.logout()

<GameScreen>:
    name: "game"
    BoxLayout:
        orientation: "vertical"
        padding: 24
        spacing: 12

        Label:
            text: "Typing Challenge"
            font_size: 32
            size_hint_y: None
            height: 60

        Label:
            text: root.phrase_text
            font_size: 22
            halign: "center"
            valign: "middle"
            text_size: self.width, None
            size_hint_y: None
            height: self.texture_size[1]

        TextInput:
            id: typing_input
            text: root.typed_text
            multiline: False
            write_tab: False
            on_text: root.typed_text = self.text
            on_text_validate: root.submit_text()

        BoxLayout:
            size_hint_y: None
            height: 48
            spacing: 12

            Button:
                text: "Submit"
                on_press: root.submit_text()

            Button:
                text: "Start"
                on_press: root.start_game()

            Button:
                text: "Quit"
                on_press:
                    root.finish_game()

        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 12

            Label:
                text: "Time: {}".format(root.timer)

            Label:
                text: "Score: {}".format(root.score)

            Label:
                text: "Mistakes: {}".format(root.mistakes)

        Label:
            text: root.status_text
            size_hint_y: None
            height: 40
            color: 0.2, 0.2, 0.8, 1

        Button:
            text: "Back to Menu"
            size_hint_y: None
            height: 48
            on_press:
                root.finish_game()

<ScoreboardScreen>:
    name: "scoreboard"
    BoxLayout:
        orientation: "vertical"
        padding: 24
        spacing: 12

        Label:
            text: "Top Typing Masters"
            font_size: 32
            size_hint_y: None
            height: 60

        ScrollView:
            GridLayout:
                id: ranking_box
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                row_default_height: 40
                row_force_default: True
                spacing: 8
                padding: 8

                Label:
                    id: no_data_label
                    text: "No ranking data yet."
                    size_hint_y: None
                    height: 40
                    opacity: 0 if root.scores else 1

        BoxLayout:
            size_hint_y: None
            height: 48
            spacing: 12

            Button:
                text: "Back to Menu"
                on_press: app.root.current = 'menu'

            Button:
                text: "Log Out"
                on_press:
                    app.current_user = None
                    app.root.current = 'login'
